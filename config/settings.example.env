# Copy this file to .env in the project ROOT (not config/) on your VPS.
# Never commit the real .env — .gitignore already excludes it.

FB_PAGE_ID=your_page_id_here
FB_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token_here

# Shared password for the review dashboard (a few team members).
# Omit entirely to disable auth (only safe on a private/VPN-only network).
DASHBOARD_TOKEN=change_me_to_a_shared_password

# --- Hosting: port + base path ---------------------------------------------
# The port uvicorn listens on. Pick one that won't clash with other apps on
# your VPS. This is passed on the uvicorn command line (see below), shown here
# for reference. Default suggestion: 8412 (uncommon, unlikely to clash).
DASHBOARD_PORT=8412

# The URL path the dashboard is served under. Your VPS uses /dashboard, so the
# full URL becomes http://<vps-ip>:<port>/dashboard
# IMPORTANT: build the frontend with the SAME value (deploy.sh handles this).
DASHBOARD_BASE_PATH=/dashboard

# Optional — only if posting to Instagram too
IG_BUSINESS_ACCOUNT_ID=
IG_ACCESS_TOKEN=
